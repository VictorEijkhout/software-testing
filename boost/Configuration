PACKAGE = boost
PACKAGEVERSION = 1.86.0
MODE = seq

CMAKETEST = \
			--title "can we compile and run" \
			has.cpp

CMAKETEST = \
			--title "file system" \
			system.cpp

CMAKETEST = \
			--title "graph viz" \
			graphviz.cpp

CMAKETEST = \
			--title "log" \
			log.cpp

exit

echo "---- Test program_options"
found=$( find $TACC_BOOST_DIR -name \*.cmake | grep program_options | wc -l )
if [ ${found} -eq 0 ] ; then
    echo "FAILED to find cmake files"
else
    echo "     found"
fi

if [ "${logfile}" = "compile.log" ] ; then
    echo "See: ${logfile}"
fi
